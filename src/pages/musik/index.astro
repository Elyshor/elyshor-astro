---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LogoHero from '../../components/LogoHero.astro';
import MusicCard from '../../components/MusicCard.astro';

const posts = (await getCollection('music', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Musik · Elyshor" description="Musikbeiträge und Tracknotizen von Elyshor.">
  <LogoHero variant="page" kicker="Musik" text="Kompakte Tracknotizen ohne Autoplay und ohne Tracking." />

  <section class="section">
    <div class="card-grid">
      {posts.map((post) => <MusicCard post={post} />)}
    </div>
  </section>
</BaseLayout>
