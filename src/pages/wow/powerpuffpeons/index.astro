---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LogoHero from '../../../components/LogoHero.astro';
---

<BaseLayout title="PowerPuffPeons · Elyshor" logoVariant="powerpuffpeons">
  <LogoHero variant="powerpuffpeons" kicker="WoW Gilde" text="EU - Blackrock" />

  <section class="section section--narrow">
    <div class="section__header">
      <p class="eyebrow">PowerPuffPeons</p>
      <h1>Gildenbereich</h1>
      <p>Hier entsteht später Platz für Gildenbeiträge, Raidnotizen und kleine Updates.</p>
    </div>
    <div class="empty-state">Noch keine Beiträge.</div>
  </section>
</BaseLayout>
