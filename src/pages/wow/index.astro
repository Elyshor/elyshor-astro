---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LogoHero from '../../components/LogoHero.astro';
import PostCard from '../../components/PostCard.astro';
import { hasTag } from '../../lib/tags';

const posts = (await getCollection('wow', ({ data }) => !data.draft))
  .filter((post) => hasTag(post.data.tags, 'wow') && !hasTag(post.data.tags, 'powerpuffpeons'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="WoW · Elyshor" description="World-of-Warcraft-Bereich von Elyshor mit Gilde, Notizen und Platz fuer Builds.">
  <LogoHero variant="page" />

  <section class="section">
    <div class="post-card-grid">
      {posts.map((post) => (
        <PostCard
          id={post.id}
          collection="wow"
          href={`/wow/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          heroImage={post.data.heroImage}
          coverImage={post.data.coverImage}
          coverAlt={post.data.coverAlt}
          coverCredit={post.data.coverCredit}
          coverSourceUrl={post.data.coverSourceUrl}
          coverProvider={post.data.coverProvider}
          coverLicense={post.data.coverLicense}
          image={post.data.image}
          albumCover={post.data.albumCover}
          section="WoW"
          sectionHref="/wow/"
        />
      ))}
    </div>
  </section>
</BaseLayout>
