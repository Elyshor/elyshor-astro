---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LogoHero from '../../components/LogoHero.astro';
import PostCard from '../../components/PostCard.astro';
import { hasAnyTag } from '../../lib/tags';

const posts = (await getCollection('tech', ({ data }) => !data.draft))
  .filter((post) => hasAnyTag(post.data.tags, ['setup', 'technik']))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Setup · Elyshor" description="Setup- und Technik-Notizen von Elyshor.">
  <LogoHero variant="page" kicker="Setup" text="Platz fuer Setup, Technik, Lieblingsgeraete und kleine Erfahrungsnotizen." />

  <section class="section" aria-label="Setup- und Technikbeitraege">
    <div class="post-card-grid">
      {posts.map((post) => (
        <PostCard
          id={post.id}
          collection="tech"
          href={`/technik/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          heroImage={post.data.heroImage}
          coverImage={post.data.coverImage}
          coverAlt={post.data.coverAlt}
          coverCredit={post.data.coverCredit}
          coverSourceUrl={post.data.coverSourceUrl}
          coverProvider={post.data.coverProvider}
          coverLicense={post.data.coverLicense}
          image={post.data.image}
          albumCover={post.data.albumCover}
          section="Technik"
          sectionHref="/setup-technik/"
        />
      ))}
    </div>
  </section>
</BaseLayout>
