---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LogoHero from '../../components/LogoHero.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('cats', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Katzen · Elyshor" description="Katzenbereich von Elyshor mit Platz fuer Fotos, kleine Geschichten und Updates.">
  <LogoHero variant="page" kicker="Katzen" text="Ein eigener kleiner Bereich fuer Katzenfotos, Geschichten und spaetere Updates." />

  <section class="section">
    <div class="section__header">
      <h1>Katzenbeitraege</h1>
      <p>Momente, Bilderideen und kurze Notizen.</p>
    </div>
    <div class="post-card-grid">
      {posts.map((post) => (
        <PostCard
          href={`/katzen/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          heroImage={post.data.heroImage}
        />
      ))}
    </div>
  </section>
</BaseLayout>
