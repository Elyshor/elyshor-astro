---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoHero from '../components/LogoHero.astro';
import MusicCard from '../components/MusicCard.astro';

const posts = (await getCollection('music', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 4);
---

<BaseLayout title="Elyshor">
  <LogoHero variant="home" text="Musik, WoW, Technik und kleine Projekte." />

  <section class="section">
    <div class="section__header">
      <p class="eyebrow">Neuste Beiträge</p>
      <h1>Frische Musiknotizen</h1>
    </div>
    <div class="card-grid">
      {posts.map((post) => <MusicCard post={post} />)}
    </div>
  </section>
</BaseLayout>
