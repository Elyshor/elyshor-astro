---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoHero from '../components/LogoHero.astro';
import PostCard from '../components/PostCard.astro';

const sections = {
  music: { label: 'Musik', href: '/musik/' },
  wow: { label: 'WoW', href: '/wow/' },
  tech: { label: 'Technik', href: '/setup-technik/' },
  cats: { label: 'Katzen', href: '/katzen/' },
} as const;

const [musicPosts, wowPosts, techPosts, catPosts] = await Promise.all([
  getCollection('music', ({ data }) => !data.draft),
  getCollection('wow', ({ data }) => !data.draft),
  getCollection('tech', ({ data }) => !data.draft),
  getCollection('cats', ({ data }) => !data.draft),
]);

const posts = [
  ...musicPosts.map((post) => ({
    ...post,
    collection: 'music',
    section: sections.music,
    href: `/musik/${post.id}/`,
    meta: [post.data.artist, post.data.track].filter(Boolean).join(' · '),
    spotifyUrl: post.data.spotifyUrl,
    youtubeUrl: post.data.youtubeUrl,
  })),
  ...wowPosts.map((post) => ({ ...post, collection: 'wow', section: sections.wow, href: `/wow/${post.id}/`, meta: '' })),
  ...techPosts.map((post) => ({ ...post, collection: 'tech', section: sections.tech, href: `/technik/${post.id}/`, meta: '' })),
  ...catPosts.map((post) => ({ ...post, collection: 'cats', section: sections.cats, href: `/katzen/${post.id}/`, meta: '' })),
].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Elyshor">
  <LogoHero variant="home" />

  <section class="ely-home-posts" aria-label="Aktuelle Beiträge">
    <div class="post-card-grid ely-post-list ely-post-list--wide">
      {posts.map((post) => (
        <PostCard
          id={post.id}
          collection={post.collection}
          href={post.href}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          heroImage={post.data.heroImage}
          coverImage={post.data.coverImage}
          coverAlt={post.data.coverAlt}
          coverCredit={post.data.coverCredit}
          coverSourceUrl={post.data.coverSourceUrl}
          coverProvider={post.data.coverProvider}
          coverLicense={post.data.coverLicense}
          image={post.data.image}
          albumCover={post.data.albumCover}
          section={post.section.label}
          sectionHref={post.section.href}
          meta={post.meta}
          spotifyUrl={post.spotifyUrl}
          youtubeUrl={post.youtubeUrl}
        />
      ))}
    </div>
  </section>
</BaseLayout>
