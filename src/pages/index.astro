---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoHero from '../components/LogoHero.astro';
import MusicCard from '../components/MusicCard.astro';

const posts = (await getCollection('music', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);
---

<BaseLayout title="Elyshor">
  <LogoHero variant="home" />

  <section class="section elyshor-home-posts">
    <div class="section__header">
      <h1>neuste beiträge</h1>
    </div>
    <div class="card-grid ely-post-list ely-post-list--wide">
      {posts.map((post) => <MusicCard post={post} />)}
    </div>
  </section>
</BaseLayout>
