---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LogoHero from '../../components/LogoHero.astro';
import PostCard from '../../components/PostCard.astro';
import { hasTag } from '../../lib/tags';

const posts = (await getCollection('wow', ({ data }) => !data.draft))
  .filter((post) => hasTag(post.data.tags, 'powerpuffpeons'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="PowerPuffPeons · Elyshor"
  description="PowerPuffPeons, die World-of-Warcraft-Gilde von Elyshor."
  logoVariant="powerpuffpeons"
>
  <LogoHero variant="powerpuffpeons" kicker="WoW Gilde" text="EU - Blackrock" />

  <section class="section section--narrow">
    <div class="section__header">
      <p class="eyebrow">PowerPuffPeons</p>
      <h1>Gildenbereich</h1>
      <p>Hier entsteht Platz fuer Gildenbeitraege, Raidnotizen und kleine Updates rund um die PowerPuffPeons.</p>
    </div>
    <div class="post-card-grid">
      {posts.map((post) => (
        <PostCard
          id={post.id}
          collection="wow"
          href={`/wow/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          heroImage={post.data.heroImage}
          coverImage={post.data.coverImage}
          coverAlt={post.data.coverAlt}
          coverCredit={post.data.coverCredit}
          coverSourceUrl={post.data.coverSourceUrl}
          coverProvider={post.data.coverProvider}
          coverLicense={post.data.coverLicense}
          image={post.data.image}
          albumCover={post.data.albumCover}
          section="PowerPuffPeons"
          sectionHref="/powerpuffpeons/"
        />
      ))}
    </div>
  </section>
</BaseLayout>
