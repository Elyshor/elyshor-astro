<button class="theme-toggle" type="button" aria-label="Farbschema wechseln" title="Farbschema wechseln">
  <span class="theme-toggle__sun" aria-hidden="true">☼</span>
  <span class="theme-toggle__moon" aria-hidden="true">☾</span>
</button>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.theme-toggle');

  toggle?.addEventListener('click', () => {
    const html = document.documentElement;
    const nextTheme = html.dataset.theme === 'light' ? 'dark' : 'light';
    html.dataset.theme = nextTheme;
    localStorage.setItem('ely_theme', nextTheme);
  });
</script>
