<div class="cookie-banner" data-cookie-banner hidden>
  <div class="cookie-banner__copy">
    <strong>Cookie- und Medienauswahl</strong>
    <p>
      Elyshor nutzt notwendige lokale Speicherung fuer diese Auswahl. Externe Medien laden wir erst nach Zustimmung.{' '}
      <a href="/datenschutz/">Datenschutz</a> · <a href="/impressum/">Impressum</a>
    </p>
    <label class="cookie-banner__choice">
      <input type="checkbox" data-consent-media />
      <span>Externe Medien von Spotify und YouTube erlauben</span>
    </label>
  </div>
  <div class="cookie-banner__actions">
    <button type="button" data-consent-accept>Alle akzeptieren</button>
    <button type="button" data-consent-necessary>Nur notwendige</button>
    <button type="button" data-consent-save>Auswahl</button>
    <button type="button" data-consent-reject>Ablehnen</button>
  </div>
</div>

<script>
  const consentKey = 'elyshor-cookie-consent';
  const legacyConsentKey = 'ely_consent';
  const banner = document.querySelector('[data-cookie-banner]');
  const mediaChoice = document.querySelector('[data-consent-media]');

  function readConsent() {
    try {
      const stored = localStorage.getItem(consentKey) || localStorage.getItem(legacyConsentKey);
      return stored ? JSON.parse(stored) : null;
    } catch {
      return null;
    }
  }

  function saveConsent(externalMedia) {
    const consent = {
      necessary: true,
      externalMedia,
      acceptedAt: new Date().toISOString(),
    };
    localStorage.setItem(consentKey, JSON.stringify(consent));
    localStorage.removeItem(legacyConsentKey);
    if (banner) banner.hidden = true;
    const event = new CustomEvent('ely-consent-updated', { detail: consent });
    document.dispatchEvent(event);
    window.dispatchEvent(event);
  }

  function syncChoice() {
    const existingConsent = readConsent();
    if (mediaChoice && existingConsent) {
      mediaChoice.checked = existingConsent.externalMedia === true;
    }
    return existingConsent;
  }

  function openBanner() {
    syncChoice();
    if (banner) banner.hidden = false;
  }

  const existingConsent = syncChoice();
  if (!existingConsent && banner) {
    banner.hidden = false;
  }

  document.querySelector('[data-consent-accept]')?.addEventListener('click', () => saveConsent(true));
  document.querySelector('[data-consent-necessary]')?.addEventListener('click', () => saveConsent(false));
  document.querySelector('[data-consent-reject]')?.addEventListener('click', () => saveConsent(false));
  document.querySelector('[data-consent-save]')?.addEventListener('click', () => saveConsent(mediaChoice?.checked === true));
  document.addEventListener('click', (event) => {
    const target = event.target;
    if (target instanceof Element && target.closest('[data-cookie-settings]')) {
      event.preventDefault();
      openBanner();
    }
  });
</script>
