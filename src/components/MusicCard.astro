---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'music'>;
}

const { post } = Astro.props;
const date = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
}).format(post.data.pubDate);
const description = [post.data.artist, post.data.track].filter(Boolean).join(' · ') || post.data.description;
const heroImage = post.data.heroImage?.startsWith('/assets/img/') ? post.data.heroImage : undefined;
---

<article class="music-card elyshor-post-card elyshor-post-card--wide">
  <a class="music-card__cover" href={`/musik/${post.id}/`} aria-label={`${post.data.title} öffnen`}>
    {heroImage ? <img src={heroImage} alt="" loading="lazy" /> : <span aria-hidden="true">♪</span>}
  </a>
  <div class="music-card__body">
    <div>
      <time datetime={post.data.pubDate.toISOString()}>{date}</time>
      <h2><a href={`/musik/${post.id}/`}>{post.data.title}</a></h2>
      <p>{description}</p>
    </div>
    <ul class="tag-list tag-list--compact" aria-label="Tags">
      {post.data.tags.slice(0, 5).map((tag) => <li>{tag}</li>)}
    </ul>
    <div class="button-row">
      {post.data.spotifyUrl && <a class="button button--ghost button--spotify" href={post.data.spotifyUrl} rel="noreferrer">Spotify</a>}
      {post.data.youtubeUrl && <a class="button button--ghost button--youtube" href={post.data.youtubeUrl} rel="noreferrer">YouTube</a>}
    </div>
  </div>
</article>
