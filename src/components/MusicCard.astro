---
import type { CollectionEntry } from 'astro:content';
import MediaButton from './MediaButton.astro';
import { getCoverForPost } from '../lib/covers';
import { getCardGradientStyle } from '../lib/cardGradients';
import { tagHref } from '../lib/tags';

interface Props {
  post: CollectionEntry<'music'>;
}

const { post } = Astro.props;
const date = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
}).format(post.data.pubDate);
const cardTitle = post.data.track || post.data.title;
const cardMeta = post.data.artist || '';
const cardDescription = cardMeta || post.data.description;
const cover = getCoverForPost('music', post.id, post.data);
const tags = ['Musik', ...post.data.tags.filter((tag) => tag.toLowerCase() !== 'musik')].slice(0, 5);

function getYouTubeId(webUrl?: string) {
  if (!webUrl) return undefined;
  try {
    const parsed = new URL(webUrl);
    if (parsed.hostname.includes('youtu.be')) {
      return parsed.pathname.split('/').filter(Boolean)[0];
    }
    if (parsed.pathname.startsWith('/shorts/') || parsed.pathname.startsWith('/embed/')) {
      return parsed.pathname.split('/').filter(Boolean)[1];
    }
    return parsed.searchParams.get('v') || undefined;
  } catch {
    return undefined;
  }
}

const youtubeId = getYouTubeId(post.data.youtubeUrl);
const cardStyle = getCardGradientStyle({
  collection: 'music',
  tags,
  title: post.data.title,
  artist: post.data.artist,
  track: post.data.track,
});
---

<article class="music-card elyshor-post-card elyshor-post-card--wide" style={cardStyle} data-media-card>
  <a class="music-card__cover" href={`/musik/${post.id}/`} aria-label={`${post.data.title} öffnen`}>
    {cover.image ? <img src={cover.image} alt={cover.alt} loading="lazy" /> : <span aria-hidden="true">♪</span>}
  </a>
  <div class="music-card__body">
    <div>
      <div class="card-meta-row">
        <time datetime={post.data.pubDate.toISOString()}>{date}</time>
        <ul class="tag-list tag-list--compact" aria-label="Tags">
          {tags.map((tag) => (
            <li>{tag.toLowerCase() === 'musik' ? <a href="/musik/">{tag}</a> : <a href={tagHref(tag)}>{tag}</a>}</li>
          ))}
        </ul>
      </div>
      <h2><a href={`/musik/${post.id}/`}>{cardTitle}</a></h2>
      {cardDescription && <p>{cardDescription}</p>}
    </div>
    <div class="button-row">
      {post.data.spotifyUrl && <MediaButton provider="Spotify" url={post.data.spotifyUrl} />}
      {post.data.youtubeUrl && <MediaButton provider="YouTube" url={post.data.youtubeUrl} />}
      <a class="button button--ghost button--read" href={`/musik/${post.id}/`}>Beitrag lesen →</a>
    </div>
    <div class="media-inline-status" data-media-status hidden></div>
    {post.data.youtubeUrl && (
      <div
        class="inline-youtube-player media-inline-panel"
        data-youtube-player
        data-youtube-panel
        data-youtube-url={post.data.youtubeUrl}
        data-youtube-id={youtubeId}
        data-youtube-title={post.data.title}
        hidden
      ></div>
    )}
  </div>
</article>
