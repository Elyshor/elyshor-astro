---
interface Props {
  provider: 'Spotify' | 'YouTube';
  url: string;
}

const { provider, url } = Astro.props;

function getSpotifyTrackId(webUrl: string) {
  if (webUrl.startsWith('spotify:track:')) {
    return webUrl.split(':')[2]?.split('?')[0];
  }

  try {
    const parsed = new URL(webUrl);
    const parts = parsed.pathname.split('/').filter(Boolean);
    const trackIndex = parts.indexOf('track');
    return trackIndex >= 0 ? parts[trackIndex + 1] : undefined;
  } catch {
    return undefined;
  }
}

function getYouTubeId(webUrl: string) {
  try {
    const parsed = new URL(webUrl);

    if (parsed.hostname.includes('youtu.be')) {
      return parsed.pathname.split('/').filter(Boolean)[0];
    }

    if (parsed.pathname.startsWith('/shorts/') || parsed.pathname.startsWith('/embed/')) {
      return parsed.pathname.split('/').filter(Boolean)[1];
    }

    return parsed.searchParams.get('v') || undefined;
  } catch {
    return undefined;
  }
}

const spotifyTrackId = provider === 'Spotify' ? getSpotifyTrackId(url) : undefined;
const youtubeId = provider === 'YouTube' ? getYouTubeId(url) : undefined;
const className = `button media-button media-action media-action--${provider.toLowerCase()} button--${provider.toLowerCase()}`;
---

{provider === 'Spotify' ? (
<button
  class={className}
  type="button"
  data-spotify-url={url}
  data-spotify-track-id={spotifyTrackId}
  aria-label="In Spotify oeffnen"
>
  <svg class="media-button__icon" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.18"></circle>
    <path fill="currentColor" d="M7.2 9.3c3.3-1 7.1-.7 9.7.8.4.2.6.8.3 1.2-.2.4-.8.5-1.2.3-2.2-1.3-5.5-1.5-8.2-.7-.5.1-.9-.1-1.1-.6-.1-.4.1-.9.5-1Zm.3 3c2.7-.8 5.7-.5 7.8.7.4.2.5.7.3 1-.2.4-.7.5-1 .3-1.7-1-4.3-1.2-6.6-.5-.4.1-.8-.1-.9-.5-.1-.4.1-.8.4-1Zm.4 2.7c2.1-.6 4.4-.4 6 .5.3.2.4.5.2.8-.2.3-.5.4-.8.2-1.3-.8-3.3-.9-5-.4-.3.1-.6-.1-.7-.4-.1-.3.1-.6.3-.7Z"></path>
  </svg>
  <span class="sr-only">Spotify</span>
</button>
) : (
<button
  class={className}
  type="button"
  data-youtube-url={url}
  data-youtube-id={youtubeId}
  aria-expanded="false"
  aria-label={`${provider} öffnen`}
>
    <svg class="media-button__icon" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" opacity="0.18" d="M21.4 7.1a3 3 0 0 0-2.1-2.1C17.5 4.5 12 4.5 12 4.5s-5.5 0-7.3.5a3 3 0 0 0-2.1 2.1A31.2 31.2 0 0 0 2.1 12c0 1.7.1 3.4.5 4.9A3 3 0 0 0 4.7 19c1.8.5 7.3.5 7.3.5s5.5 0 7.3-.5a3 3 0 0 0 2.1-2.1c.4-1.5.5-3.2.5-4.9s-.1-3.4-.5-4.9Z"></path>
      <path fill="currentColor" d="m10 15.4 5.2-3.4L10 8.6v6.8Z"></path>
    </svg>
  <span class="sr-only">YouTube</span>
</button>
)}
