---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  logoVariant?: 'elyshor' | 'powerpuffpeons';
}

const { logoVariant = 'elyshor' } = Astro.props;
const navItems = [
  { href: '/', label: 'Start' },
  { href: '/musik/', label: 'Musik' },
  { href: '/wow/', label: 'WoW' },
  { href: '/powerpuffpeons/', label: 'PowerPuffPeons' },
  { href: '/setup/', label: 'Setup' },
  { href: '/technik/', label: 'Technik' },
  { href: '/katzen/', label: 'Katzen' },
  { href: '/about/', label: 'Über mich' },
];
---

<header class="site-header">
  <a class="header-mark" href="/" aria-label="Elyshor Startseite">
    {logoVariant === 'powerpuffpeons' ? 'PPP' : 'ELY'}
  </a>
  <nav class="main-nav" aria-label="Hauptnavigation">
    {navItems.map((item) => (
      <a href={item.href}>
        <span>{item.label}</span>
        {item.sublabel && <small>{item.sublabel}</small>}
      </a>
    ))}
  </nav>
  <ThemeToggle />
</header>
