---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: '/musik/', label: 'Musik' },
  { href: '/wow/', label: 'WoW' },
  { href: '/powerpuffpeons/', label: 'PowerPuffPeons' },
  { href: '/setup-technik/', label: 'Setup & Technik' },
  { href: '/links/', label: 'Links' },
];
---

<header class="site-header" id="site-header">
  <div class="site-header__inner">
    <a class="site-logo" href="/" aria-label="Elyshor Startseite">
      <img src="/assets/img/ely-logo-header-cropped.webp" alt="Elyshor" width="72" height="72" />
    </a>

    <nav class="main-nav site-nav" aria-label="Hauptnavigation">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="site-header__actions">
      <ThemeToggle />
    </div>
  </div>
</header>
