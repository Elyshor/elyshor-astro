---
import MediaButton from './MediaButton.astro';
import { tagHref } from '../lib/tags';

interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  heroImage?: string;
  coverImage?: string;
  image?: string;
  albumCover?: string;
  section?: string;
  sectionHref?: string;
  meta?: string;
  spotifyUrl?: string;
  youtubeUrl?: string;
}

const {
  href,
  title,
  description,
  pubDate,
  tags = [],
  heroImage,
  coverImage,
  image,
  albumCover,
  section,
  sectionHref,
  meta,
  spotifyUrl,
  youtubeUrl,
} = Astro.props;
const formattedDate = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
}).format(pubDate);
const rawImage = coverImage || albumCover || image || heroImage;
const cardImage = rawImage?.startsWith('/assets/img/') ? rawImage : undefined;
const displayTags = section ? [section, ...tags.filter((tag) => tag.toLowerCase() !== section.toLowerCase())] : tags;

function getYouTubeId(webUrl?: string) {
  if (!webUrl) return undefined;
  try {
    const parsed = new URL(webUrl);
    if (parsed.hostname.includes('youtu.be')) {
      return parsed.pathname.split('/').filter(Boolean)[0];
    }
    if (parsed.pathname.startsWith('/shorts/') || parsed.pathname.startsWith('/embed/')) {
      return parsed.pathname.split('/').filter(Boolean)[1];
    }
    return parsed.searchParams.get('v') || undefined;
  } catch {
    return undefined;
  }
}

const youtubeId = getYouTubeId(youtubeUrl);
---

<article class:list={['post-card elyshor-post-card', { 'post-card--has-image': cardImage }]}>
  {cardImage && (
    <a class="post-card__image" href={href} aria-label={`${title} öffnen`}>
      <img src={cardImage} alt="" loading="lazy" />
    </a>
  )}
  <div class="post-card__body">
    <div class="card-meta-row">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      {displayTags.length > 0 && (
        <ul class="tag-list tag-list--compact" aria-label="Tags">
          {displayTags.slice(0, 5).map((tag) => (
            <li>{sectionHref && tag === section ? <a href={sectionHref}>{tag}</a> : <a href={tagHref(tag)}>{tag}</a>}</li>
          ))}
        </ul>
      )}
    </div>
    <h2><a href={href}>{title}</a></h2>
    {meta && <p class="post-card__meta">{meta}</p>}
    <p>{description}</p>
    <div class="button-row">
      {spotifyUrl && <MediaButton provider="Spotify" url={spotifyUrl} />}
      {youtubeUrl && <MediaButton provider="YouTube" url={youtubeUrl} />}
      <a class="button button--read" href={href}>Beitrag lesen →</a>
    </div>
    {youtubeId && <div class="media-inline-panel" data-youtube-panel data-youtube-id={youtubeId} data-youtube-title={title} hidden></div>}
  </div>
</article>
