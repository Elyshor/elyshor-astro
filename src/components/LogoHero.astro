---
interface Props {
  variant?: 'home' | 'page' | 'powerpuffpeons';
  kicker?: string;
  text?: string;
}

const { variant = 'page', kicker, text } = Astro.props;
const isPower = variant === 'powerpuffpeons';
const className = `logo-hero logo-hero--${variant}`;
const elyLogo = variant === 'home'
  ? '/assets/img/elyshor-logo-transparent-cropped.webp'
  : '/assets/img/elyshor-logo.webp';
---

<section class={className}>
  {kicker && <p class="eyebrow">{kicker}</p>}
  <div class="logo-hero__mark" aria-label={isPower ? 'PowerPuffPeons' : 'Elyshor'}>
    {isPower ? (
      <img src="/assets/img/powerpuff-peons-logo.webp" alt="PowerPuffPeons" />
    ) : (
      <img src={elyLogo} alt="Elyshor" />
    )}
  </div>
  {text && <p>{text}</p>}
</section>
