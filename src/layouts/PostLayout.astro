---
import BaseLayout from './BaseLayout.astro';
import SpotifyEmbed from '../components/SpotifyEmbed.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  spotify: string;
  youtube?: string;
}

const { title, date, tags, spotify, youtube } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(date);
---

<BaseLayout title={`${title} · Elyshor`} description={`${title} auf Elyshor.`}>
  <article class="post-shell">
    <header class="post-header">
      <p class="eyebrow">Musik</p>
      <h1>{title}</h1>
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <ul class="tag-list" aria-label="Tags">
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
    </header>

    <div class="prose">
      <slot />
    </div>

    <section class="embed-stack" aria-label="Externe Medien">
      <SpotifyEmbed url={spotify} title={title} />
      {youtube && <YouTubeEmbed url={youtube} title={title} />}
    </section>
  </article>
</BaseLayout>
