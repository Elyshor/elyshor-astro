---
import BaseLayout from './BaseLayout.astro';
import MediaButton from '../components/MediaButton.astro';
import { getCoverForPost } from '../lib/covers';
import { getCardGradientStyle } from '../lib/cardGradients';

interface Props {
  id?: string;
  collection?: 'music' | 'wow' | 'tech' | 'cats';
  section: string;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  coverImage?: string;
  coverAlt?: string;
  coverCredit?: string;
  coverSourceUrl?: string;
  coverProvider?: string;
  coverLicense?: string;
  image?: string;
  heroImage?: string;
  albumCover?: string;
  spotifyUrl?: string;
  youtubeUrl?: string;
}

const {
  id,
  collection = 'music',
  section,
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  coverImage,
  coverAlt,
  coverCredit,
  coverSourceUrl,
  coverProvider,
  coverLicense,
  image,
  heroImage,
  albumCover,
  spotifyUrl,
  youtubeUrl,
} = Astro.props;
const formattedDate = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(pubDate);
const formattedUpdatedDate = updatedDate && new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(updatedDate);

function getYouTubeId(webUrl?: string) {
  if (!webUrl) return undefined;
  try {
    const parsed = new URL(webUrl);
    const parts = parsed.pathname.split('/').filter(Boolean);

    if (parsed.hostname.includes('youtu.be')) {
      return parts[0];
    }

    if (parts[0] === 'embed' || parts[0] === 'shorts') {
      return parts[1];
    }

    return parsed.searchParams.get('v') || undefined;
  } catch {
    return undefined;
  }
}

const youtubeId = getYouTubeId(youtubeUrl);
const cover = getCoverForPost(collection, id, {
  title,
  coverImage,
  coverAlt,
  coverCredit,
  coverSourceUrl,
  coverProvider,
  coverLicense,
  image,
  heroImage,
  albumCover,
});
const postGradientStyle = collection === 'music'
  ? getCardGradientStyle({ collection, tags, title, track: title })
  : undefined;
---

<BaseLayout title={`${title} · Elyshor`} description={description} ogType="article">
  <article class:list={['post-shell', postGradientStyle && 'post-shell--music-gradient']} style={postGradientStyle} data-media-card data-post-gradient={postGradientStyle ? '' : undefined}>
    <header class="post-header">
      <p class="eyebrow">{section}</p>
      <h1>{title}</h1>
      <p>{description}</p>
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      {formattedUpdatedDate && <p class="post-updated">Aktualisiert am {formattedUpdatedDate}</p>}
      {tags.length > 0 && (
        <ul class="tag-list" aria-label="Tags">
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    {(spotifyUrl || youtubeUrl) && (
      <section class="embed-stack post-media-actions" aria-label="Externe Medien">
        <div class="button-row">
          {spotifyUrl && <MediaButton provider="Spotify" url={spotifyUrl} />}
          {youtubeUrl && <MediaButton provider="YouTube" url={youtubeUrl} />}
        </div>
        <div class="media-inline-status" data-media-status hidden></div>
        {youtubeUrl && (
          <div
            class="inline-youtube-player media-inline-panel"
            data-youtube-player
            data-youtube-panel
            data-youtube-url={youtubeUrl}
            data-youtube-id={youtubeId}
            data-youtube-title={title}
            hidden
          ></div>
        )}
      </section>
    )}
    {cover.credit && (
      <p class="post-cover-credit">
        Bild: {cover.sourceUrl ? <a href={cover.sourceUrl} target="_blank" rel="noopener noreferrer">{cover.credit}</a> : cover.credit}
      </p>
    )}
  </article>
</BaseLayout>
